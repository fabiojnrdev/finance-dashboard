# ─── Database ───────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://fintrack:fintrack@db:3306/fintrack

# ─── Security ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── MySQL ───────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=fintrack
MYSQL_USER=fintrack
MYSQL_PASSWORD=fintrack

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1

# ─── AI (optional, for category suggestions) ─────────────────
# OPENAI_API_KEY=sk-...

# ─── Environment ─────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
